# ─── Cloudflare R2 / S3-compatible storage ───────────────────────────────────
# Endpoint format: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY=your_r2_access_key
R2_SECRET_KEY=your_r2_secret_key
R2_BUCKET=your-bucket-name

# Public base URL for generating asset URLs (no trailing slash)
# Use your R2 public URL or custom domain
R2_PUBLIC_BASE_URL=https://assets.yourdomain.com

# ─── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# gpt-4o for vision analysis (most capable), gpt-4o-mini for metadata (cheaper)
VISION_MODEL=gpt-4o
METADATA_MODEL=gpt-4o-mini

# ─── Pipeline tuning ─────────────────────────────────────────────────────────
# Path for the SQLite database
DB_PATH=outputs/pipeline.db

# Directory for JSON/CSV output
OUTPUT_DIR=outputs

# How many images to send to vision API concurrently
BATCH_SIZE=10

# Retry attempts for failed API calls
MAX_RETRIES=3

# ─── Clustering ──────────────────────────────────────────────────────────────
# Minimum cluster size for HDBSCAN (tune based on dataset size)
# Smaller = more, finer clusters. For 10k images try 15-30.
HDBSCAN_MIN_CLUSTER_SIZE=10
HDBSCAN_MIN_SAMPLES=5

# ─── Embeddings ──────────────────────────────────────────────────────────────
# CLIP model — clip-ViT-B-32 is fast; clip-ViT-L-14 is higher quality
CLIP_MODEL=clip-ViT-B-32
