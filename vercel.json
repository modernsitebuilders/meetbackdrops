{
  "functions": {
    "pages/api/sitemap.js": {
      "maxDuration": 10
    }
  },
  "redirects": [
    {
      "source": "/premium",
      "destination": "/category/office-spaces",
      "permanent": true
    },
    {
      "source": "/category/home-offices",
      "destination": "/category/office-spaces",
      "permanent": true
    },
    {
      "source": "/category/executive-offices",
      "destination": "/category/office-spaces",
      "permanent": true
    },
    {
      "source": "/category/lobbies",
      "destination": "/category/ambient-lighting",
      "permanent": true
    },
    {
      "source": "/category/private-offices",
      "destination": "/category/office-spaces",
      "permanent": true
    },
    {
      "source": "/category/open-offices",
      "destination": "/category/office-spaces",
      "permanent": true
    },
    {
      "source": "/category/lounges",
      "destination": "/category/office-spaces",
      "permanent": true
    },
    {
      "source": "/category/home-lifestyle",
      "destination": "/category/well-lit",
      "permanent": true
    },
    {
      "source": "/category/professional-shelves",
      "destination": "/category/ambient-lighting",
      "permanent": true
    },
    {
      "source": "/search",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/category/conference-rooms",
      "destination": "/category/office-spaces",
      "permanent": true
    },
    {
      "source": "/category/minimalist",
      "destination": "/category/well-lit",
      "permanent": true
    },
    {
      "source": "/category/ambiant-lighting",
      "destination": "/category/ambient-lighting",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.googletagmanager.com https://cdn-cookieyes.com https://stream-backdrops-videos.s3.amazonaws.com; style-src 'self' 'unsafe-inline' https://cdn-cookieyes.com; img-src 'self' data: https:; font-src 'self' data: https://cdn-cookieyes.com; connect-src 'self' https://www.google-analytics.com https://cdn-cookieyes.com https://log.cookieyes.com https://api.cookieyes.com; media-src 'self' https://stream-backdrops-videos.s3.amazonaws.com;"
        }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/api/sitemap",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    },
    {
      "source": "/api/robots",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    }
  ]
}