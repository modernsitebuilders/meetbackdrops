{
  "functions": {
    "pages/api/sitemap.js": {
      "maxDuration": 10
    }
  },
  "redirects": [
    {
      "source": "https://www.streambackdrops.com/:path*",
      "destination": "https://streambackdrops.com/:path*",
      "permanent": true
    },
    {
      "source": "/premium",
      "destination": "/category/office-spaces",
      "permanent": true
    },
    {
      "source": "/category/home-offices",
      "destination": "/category/office-spaces",
      "permanent": true
    },
    {
      "source": "/category/executive-offices",
      "destination": "/category/office-spaces",
      "permanent": true
    },
    {
      "source": "/category/lobbies",
      "destination": "/category/ambient-lighting",
      "permanent": true
    },
    {
      "source": "/category/private-offices",
      "destination": "/category/office-spaces",
      "permanent": true
    },
    {
      "source": "/category/open-offices",
      "destination": "/category/office-spaces",
      "permanent": true
    },
    {
      "source": "/category/lounges",
      "destination": "/category/office-spaces",
      "permanent": true
    },
    {
      "source": "/category/home-lifestyle",
      "destination": "/category/well-lit",
      "permanent": true
    },
    {
      "source": "/category/professional-shelves",
      "destination": "/category/ambient-lighting",
      "permanent": true
    },
    {
      "source": "/search",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/sitemap.xml",
      "destination": "/api/sitemap",
      "permanent": true
    },
    {
      "source": "/robots.txt",
      "destination": "/api/robots",
      "permanent": true
    },
    {
      "source": "/category/conference-rooms",
      "destination": "/category/office-spaces",
      "permanent": true
    },
    {
      "source": "/category/minimalist",
      "destination": "/category/well-lit",
      "permanent": true
    },
    {
      "source": "/category/ambiant-lighting",
      "destination": "/category/ambient-lighting",
      "permanent": true
    },
    {
      "source": "/search*",
      "destination": "/",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/images/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/api/sitemap",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    },
    {
      "source": "/api/robots",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    }
  ]
}